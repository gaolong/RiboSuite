params {

  // cutadapt trimming
  cutadapt_min_len      = 25
  cutadapt_max_len      = 42

  // trimming success criterion
  cutadapt_success_frac     = 0.80
  cutadapt_min_adapter_frac = 0.85

  // adapter rescue
  cutadapt_subsample_n  = 200000
  cutadapt_min_overlap  = 10
  adapter_sequence = null

  min_length = 25
  max_length = 42

  enable_umi         = false
  umi_extract_method = "regex"
  umi_bc_pattern     = '^(?P<umi_1>.{8}).+$'

  contam_index   = "/data/holwm/Jiemin/OAPAHepg2_13102025/deepseq/bowtie_index/rrna-trna-index"
  star_index     = "/data/holwm/home/gaolong/projects/RiboSuite/reference/human/GRCh38/star"
  star_rna_index = star_index

  metagene_window          = 50
  metagene_max_tx_per_gene = 1

  outdir = "results"

  star_quantmode          = false
  star_rescue_unique_pct  = 30

  publish_fastq           = false
  enable_translated_orfs  = true

  // -------------------------
  // RNA quant (featureCounts)
  // -------------------------
  rna_quant_paired       = true
  rna_quant_strandedness = 0     // default unstranded
  rna_quant_feature_type = "exon"
  rna_quant_gene_attr    = "gene_id"
  rna_quant_extra_args   = ""

  // -------------------------
  // RNA tracks (bigWig)
  // -------------------------
  rna_track_mode         = "all"   // default unstranded BW only
  rna_track_strandedness = 0       // default unstranded
  rna_track_paired       = true

  // -------------------------
  // P-site tracks (bigWig)
  // -------------------------
  enable_psite_track = true       // default OFF
  psite_track_mode   = "all"       // if enabled, default is unstranded/all BW only
  psite_by_length    = false
}



profiles {

    // ============================================================
    // Local testing
    // ============================================================
    standard {

        process {
            executor = 'local'
            cpus     = 1
            memory   = '40 GB'
        }

        conda {
            enabled  = true
        }
    }


    // ============================================================
    // HPC (PBS)
    // ============================================================
    hpc {

        // -----------------------------
        // Shared resource presets
        // -----------------------------
        BIG_MEM   = '32 GB'
        BIG_CPUS = 4
        BIG_TIME = '12h'

        process {

            executor = 'local'
            queue    = 'workq'
            cpus     = 4
            memory   = '16 GB'
            time     = '24h'

            errorStrategy = 'retry'
            maxRetries    = 2

            // -----------------------------
            // Heavy process overrides
            // -----------------------------

            withName: CUTADAPT_TRIM {
                cpus   = BIG_CPUS
                memory = BIG_MEM
                time   = "2h"
            }
            
            withName: BOWTIE2_FILTER {
                cpus   = BIG_CPUS
                memory = BIG_MEM
                time   = BIG_TIME
            }

            withName: STAR_ALIGN {
                cpus   = BIG_CPUS
                memory = BIG_MEM
                time   = BIG_TIME
            }

            withName: SAMTOOLS_INDEX {
                cpus   = BIG_CPUS
                memory = BIG_MEM
                time   = '2h'
            }

            withName: UMI_DEDUP {
                cpus   = BIG_CPUS
                memory = BIG_MEM
                time   = "2h"
            }
        }

        executor {
            queueSize = 50
        }

        conda {
            enabled = true
        }

        cleanup = false
    }

    // ============================================================
    // PBS batch submission (REAL cluster usage)
    // ============================================================
    pbs {

        BIG_MEM   = '48 GB'
        BIG_CPUS = 4
        BIG_TIME = '12h'

        process {

        //    withName: CDS_QUANT {
        //        cache = false
        //   }

        //    withName: FRAME_PERIODICITY_QC {
        //        cache = false
        //    }

        //    withName: PSITE_TRACK {
        //        cache = false
        //    }

            executor = 'pbs'
            queue    = 'workq'

            cpus     = 1
            memory   = '32 GB'
            time     = '24h'

            errorStrategy = 'retry'
            maxRetries    = 2

            withName: CUTADAPT_TRIM {
                cpus   = BIG_CPUS
                memory = BIG_MEM
                time   = '2h'
            }

            withName: FASTP {
                cpus   = BIG_CPUS
                memory = BIG_MEM
                time   = BIG_TIME
            }

            withName: BOWTIE2_FILTER {
                cpus   = BIG_CPUS
                memory = BIG_MEM
                time   = BIG_TIME
            }

            withName: STAR_RIBO_ALIGN {
                cpus   = BIG_CPUS
                memory = BIG_MEM
                time   = BIG_TIME
            }

            withName: STAR_RNA_ALIGN {
                cpus   = BIG_CPUS
                memory = BIG_MEM
                time   = BIG_TIME
            }

            withName: SAMTOOLS_INDEX {
                cpus   = BIG_CPUS
                memory = BIG_MEM
                time   = '2h'
            }
        }

        executor {
            queueSize = 6
        }

        conda {
            enabled = true
        }

        cleanup = false
    }

}
